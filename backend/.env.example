NODE_ENV=development
PORT=4000
HOST=0.0.0.0
DATABASE_URL=postgresql://morph:morph@localhost:5432/morph_payments?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-a-long-random-secret

# Morph Hoodi Testnet by default. Override when hackathon docs specify a dedicated RPC.
MORPH_CHAIN_ID=2910
MORPH_RPC_URL=https://rpc-hoodi.morph.network
MORPH_EXPLORER_URL=https://explorer-hoodi.morph.network
MORPH_USDC_ADDRESS=0x0000000000000000000000000000000000000000
RELAYER_PRIVATE_KEY=

# AI provider. The code is OpenAI-ready and can be adapted to Grok by swapping the client.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
